<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CryPTrus 2.0 - Secure Vault</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.2.0/crypto-js.min.js"></script>
    <style>
        body { background: #0d0d0d; color: #00ff41; font-family: 'Courier New', monospace; display: flex; flex-direction: column; align-items: center; padding-top: 30px; }
        .container { background: #1a1a1a; padding: 30px; border-radius: 10px; border: 2px solid #00ff41; width: 90%; max-width: 600px; box-shadow: 0 0 20px #00ff41; }
        .mode-toggle { display: flex; justify-content: space-around; margin-bottom: 20px; }
        .mode-btn { background: none; border: 1px solid #00ff41; color: #00ff41; padding: 10px 20px; cursor: pointer; font-family: inherit; flex: 1; margin: 0 5px; }
        .mode-btn.active { background: #00ff41; color: #000; font-weight: bold; }
        textarea { width: 100%; padding: 12px; margin-top: 10px; background: #000; border: 1px solid #00ff41; color: #00ff41; box-sizing: border-box; font-family: inherit; font-size: 14px; }
        label { font-weight: bold; margin-top: 20px; display: block; text-transform: uppercase; letter-spacing: 2px; }
        
        /* Button Group Styling */
        .btn-group { display: flex; gap: 10px; margin-top: 15px; }
        .action-btn { flex: 1; padding: 12px; font-weight: bold; cursor: pointer; font-family: inherit; border: none; transition: 0.2s; }
        #copyBtn { background: #00ff41; color: #000; }
        #downloadBtn { background: #000; color: #00ff41; border: 1px solid #00ff41; }
        .action-btn:hover { opacity: 0.8; transform: scale(1.02); }
    </style>
</head>
<body>

    <h1>⚡ CRYPTRUS 2.0- ⚡</h1>
    
    <div class="container">
        <div class="mode-toggle">
            <button id="encMode" class="mode-btn active">ENCRYPT</button>
            <button id="decMode" class="mode-btn">DECRYPT</button>
        </div>

        <label id="inputLabel">Input:</label>
        <textarea id="userInput" rows="3" placeholder="Enter text..."></textarea>

        <label id="outputLabel">Output:</label>
        <textarea id="outputField" rows="5" readonly placeholder="Result will appear here..."></textarea>
        
        <div class="btn-group">
            <button id="copyBtn" class="action-btn">COPY</button>
            <button id="downloadBtn" class="action-btn">DOWNLOAD .TXT</button>
        </div>
    </div>

    <script>
        const secretKey = "my-ultra-secure-key-123";
        let isEncryptMode = true;

        const userInput = document.getElementById('userInput');
        const outputField = document.getElementById('outputField');
        const encBtn = document.getElementById('encMode');
        const decBtn = document.getElementById('decMode');
        const copyBtn = document.getElementById('copyBtn');
        const downloadBtn = document.getElementById('downloadBtn');

        // Logic for Encrypt/Decrypt
        function process() {
            const val = userInput.value;
            if (!val) { outputField.value = ""; return; }
            try {
                if (isEncryptMode) {
                    outputField.value = CryptoJS.AES.encrypt(val, secretKey).toString();
                } else {
                    const bytes = CryptoJS.AES.decrypt(val, secretKey);
                    outputField.value = bytes.toString(CryptoJS.enc.Utf8) || "INVALID DATA";
                }
            } catch (e) { outputField.value = "ERROR"; }
        }

        userInput.addEventListener('input', process);

        // Mode Switching
        encBtn.addEventListener('click', () => { isEncryptMode = true; encBtn.classList.add('active'); decBtn.classList.remove('active'); process(); });
        decBtn.addEventListener('click', () => { isEncryptMode = false; decBtn.classList.add('active'); encBtn.classList.remove('active'); process(); });

        // Copy Feature
        copyBtn.addEventListener('click', () => {
            navigator.clipboard.writeText(outputField.value).then(() => {
                copyBtn.innerText = "COPIED!";
                setTimeout(() => copyBtn.innerText = "COPY", 1500);
            });
        });

        // Download Feature
        downloadBtn.addEventListener('click', () => {
            const text = outputField.value;
            if (!text) return;

            const blob = new Blob([text], { type: 'text/plain' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            
            a.href = url;
            a.download = isEncryptMode ? 'encrypted_message.txt' : 'decrypted_message.txt';
            a.click();
            window.URL.revokeObjectURL(url);
        });
    </script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CryPTrus 2.0 - Secure Vault</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.2.0/crypto-js.min.js"></script>
    <style>
        body { background: #0d0d0d; color: #00ff41; font-family: 'Courier New', monospace; display: flex; flex-direction: column; align-items: center; padding-top: 30px; }
        .container { background: #1a1a1a; padding: 30px; border-radius: 10px; border: 2px solid #00ff41; width: 90%; max-width: 600px; box-shadow: 0 0 20px #00ff41; }
        .mode-toggle { display: flex; justify-content: space-around; margin-bottom: 20px; }
        .mode-btn { background: none; border: 1px solid #00ff41; color: #00ff41; padding: 10px 20px; cursor: pointer; font-family: inherit; flex: 1; margin: 0 5px; }
        .mode-btn.active { background: #00ff41; color: #000; font-weight: bold; }
        input, textarea { width: 100%; padding: 12px; margin-top: 10px; background: #000; border: 1px solid #00ff41; color: #00ff41; box-sizing: border-box; font-family: inherit; font-size: 14px; }
        label { font-weight: bold; margin-top: 20px; display: block; text-transform: uppercase; letter-spacing: 2px; }
        #actionBtn { width: 100%; margin-top: 15px; padding: 12px; background: #00ff41; color: #1a1a1a; border: none; font-weight: bold; cursor: pointer; font-family: inherit; }
    </style>
</head>
<body>

    <h1>⚡ CRYPTRUS 2.0 ⚡</h1>
    
    <div class="container">
        <div class="mode-toggle">
            <button id="encMode" class="mode-btn active">ENCRYPT</button>
            <button id="decMode" class="mode-btn">DECRYPT</button>
        </div>

        <label id="inputLabel">Message to Encrypt:</label>
        <textarea id="userInput" rows="3" placeholder="Enter text..."></textarea>

        <label id="outputLabel">AES Ciphertext:</label>
        <textarea id="outputField" rows="3" readonly placeholder="Result will appear here..."></textarea>
        
        <button id="actionBtn">COPY RESULT</button>
    </div>

    <script>
        const secretKey = "my-ultra-secure-key-123";
        let isEncryptMode = true;

        const userInput = document.getElementById('userInput');
        const outputField = document.getElementById('outputField');
        const encBtn = document.getElementById('encMode');
        const decBtn = document.getElementById('decMode');
        const actionBtn = document.getElementById('actionBtn');

        // Mode Switching Logic
        encBtn.addEventListener('click', () => {
            isEncryptMode = true;
            encBtn.classList.add('active');
            decBtn.classList.remove('active');
            document.getElementById('inputLabel').innerText = "Message to Encrypt:";
            document.getElementById('outputLabel').innerText = "AES Ciphertext:";
            process();
        });

        decBtn.addEventListener('click', () => {
            isEncryptMode = false;
            decBtn.classList.add('active');
            encBtn.classList.remove('active');
            document.getElementById('inputLabel').innerText = "Ciphertext to Decrypt:";
            document.getElementById('outputLabel').innerText = "Original Message:";
            process();
        });

        // Core Processing Logic
        function process() {
            const val = userInput.value;
            if (!val) { outputField.value = ""; return; }

            try {
                if (isEncryptMode) {
                    outputField.value = CryptoJS.AES.encrypt(val, secretKey).toString();
                } else {
                    const bytes = CryptoJS.AES.decrypt(val, secretKey);
                    const originalText = bytes.toString(CryptoJS.enc.Utf8);
                    outputField.value = originalText || "ERROR: Invalid Key or Cipher";
                }
            } catch (e) {
                outputField.value = "ERROR: Decryption Failed";
            }
        }

        userInput.addEventListener('input', process);

        // Copy Logic
        actionBtn.addEventListener('click', () => {
            if (!outputField.value) return;
            navigator.clipboard.writeText(outputField.value).then(() => {
                const oldText = actionBtn.innerText;
                actionBtn.innerText = "COPIED!";
                setTimeout(() => actionBtn.innerText = oldText, 1500);
            });
        });
    </script>
</body>
</html>

[MASTER]
# Ignore trailing whitespace, missing docstrings, and long lines for now
disable=
    C0303, # trailing-whitespace
    C0301, # line-too-long
    C0114, # missing-module-docstring
    C0116, # missing-function-docstring
    C0103, # invalid-name
    W0718, # broad-exception-caught
    W0122  # exec-used

